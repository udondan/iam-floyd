{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowOAuthForAWSMCP",
      "Effect": "Allow",
      "Action": [
        "signin:AuthorizeOAuth2Access",
        "signin:CreateOAuth2Token"
      ],
      "Resource": "arn:aws:signin:*:*:service-principal/aws-mcp.amazonaws.com"
    }
  ]
}